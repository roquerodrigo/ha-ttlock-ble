#!/usr/bin/env bash

set -e

cd "$(dirname "$0")/.."

# Auto-use ./.venv if present so callers don't need to `source activate`.
if [ -d "${PWD}/.venv" ]; then
    export PATH="${PWD}/.venv/bin:${PATH}"
    export VIRTUAL_ENV="${PWD}/.venv"
fi

# Create config dir if not present
if [[ ! -d "${PWD}/config" ]]; then
    mkdir -p "${PWD}/config"
    hass --config "${PWD}/config" --script ensure_config
fi

# Set the path to custom_components
## This let's us have the structure we want <root>/custom_components/ttlock_ble
## while at the same time have Home Assistant configuration inside <root>/config
## without resulting to symlinks.
##
## We add the project root (not <root>/custom_components) so HA's loader can do
## `import custom_components` while `from ttlock_ble import …` still resolves to
## the SDK package in site-packages — otherwise the integration's own
## `custom_components/ttlock_ble/` would shadow the SDK at runtime.
export PYTHONPATH="${PYTHONPATH}:${PWD}"

# Start Home Assistant
hass --config "${PWD}/config" --debug

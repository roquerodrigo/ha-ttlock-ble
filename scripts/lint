#!/usr/bin/env bash

set -e

cd "$(dirname "$0")/.."

# Auto-use ./.venv if present so callers don't need to `source activate`.
if [ -d "${PWD}/.venv" ]; then
    export PATH="${PWD}/.venv/bin:${PATH}"
    export VIRTUAL_ENV="${PWD}/.venv"
fi

ruff format .
ruff check . --fix
mypy custom_components/integration_blueprint
